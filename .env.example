# At least one LLM provider key is required
DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# Chinese domestic providers
# ALIBABA_API_KEY=sk-...          # Qwen (通义千问) — https://dashscope.console.aliyun.com/apiKey
# ZHIPU_API_KEY=...               # GLM (智谱) — https://open.bigmodel.cn/usercenter/apikeys
# MOONSHOT_API_KEY=sk-...         # Kimi (月之暗面) — https://platform.moonshot.cn/console/api-keys

# Optional: web search (Tavily)
# TAVILY_API_KEY=tvly-...

# Default model for inspection / auto-fix (chat uses shared/constants.ts defaults)
# DEFAULT_PROVIDER=deepseek       # fallback provider for inspection if INSPECTOR_PROVIDER is not set
# DEFAULT_MODEL=deepseek-v4-flash # fallback model for inspection if INSPECTOR_MODEL is not set

# Override model specifically for inspection, behavior analysis, and auto-fix
# INSPECTOR_PROVIDER=deepseek     # deepseek | openai | anthropic
# INSPECTOR_MODEL=deepseek-v4-flash

# Server
PORT=3000
# DB_PATH=./data/evo.db
